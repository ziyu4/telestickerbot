# Telegram Bot Configuration
# Required: Get your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# BOT_OWNER_ID=123456789
# TELEGRAM_API_URL=http://localhost:8081

# Database Configuration
# Option 1: Local SQLite (default)
SQLITE_PATH=stickerbot.db

# Option 2: Turso remote database (uncomment to use)
# DATABASE_URL=libsql://your-database.turso.io

# Webhook Configuration (optional, enables webhook mode)
# Required for production deployments
# WEBHOOK_URL=https://your-domain.com/webhook
# WEBHOOK_SECRET=your_secret_token_at_least_32_characters_long
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8811